###############################################################################
# Dockerfile.agent — Single image for ALL MASS Python agents and managers
# Build context: MASS/  (project root, one level above docker/)
#
# No apt-get — all packages have pre-built aarch64/x86_64 wheels on PyPI.
# The pip layer is cached after the first build, so code-only rebuilds work
# fully offline (requirements.txt unchanged → cached layer reused).
###############################################################################

FROM python:3.12-slim

WORKDIR /app

# Install Python dependencies (cached unless requirements.txt changes)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy full project source
COPY . .

# Non-root user for security (NIST SP 800-190)
RUN useradd -r -u 1001 -g root massagent \
    && chown -R massagent:root /app
USER massagent

# Python socket healthcheck — no curl/netcat needed, no external tool attack surface.
# Connects to the agent's FastAPI port; fails fast (3s timeout) if the server is down.
HEALTHCHECK --interval=15s --timeout=5s --retries=3 \
    CMD python3 -c \
        "import socket,os,sys; s=socket.socket(); s.settimeout(3); \
         s.connect(('127.0.0.1',int(os.environ.get('HEALTH_PORT','8000')))); \
         s.close(); sys.exit(0)" \
    || exit 1
