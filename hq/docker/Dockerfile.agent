###############################################################################
# Dockerfile.agent — Single image for ALL MASS Python agents and managers
# Build context: MASS/  (project root, one level above docker/)
###############################################################################

FROM python:3.12-slim

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
        gcc libssl-dev curl netcat-traditional \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install Python dependencies (cached unless requirements.txt changes)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy full project source
COPY . .

# Non-root user for security (NIST SP 800-190)
RUN useradd -r -u 1001 -g root massagent \
    && chown -R massagent:root /app
USER massagent

# Default healthcheck — each service overrides HEALTH_PORT via env
HEALTHCHECK --interval=15s --timeout=5s --retries=3 \
    CMD curl -sf http://localhost:${HEALTH_PORT:-8000}/health || exit 1
